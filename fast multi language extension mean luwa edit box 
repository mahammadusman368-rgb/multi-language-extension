  local emoji = ""
  
  -- Mood Detection Rules
  if t:find("hah") or t:find("funny") or t:find("mazak") or t:find("hansi") or t:find("joke") then
    emoji = " 馃槀馃ぃ馃槅"
  elseif t:find("sad") or t:find("rona") or t:find("dukh") or t:find("sorry") or t:find("gham") then
    emoji = " 馃槦馃槶馃挃"
