      end)
      local ld = lb.create()
      ld.getWindow().setType(2032)
      ld.show()
    elseif which == 1 then
      service.setSharedData("vibrate_on", service.getSharedData("vibrate_on") == "true" and "false" or "true")
      showSettingsMenu()
    elseif which == 2 then
      service.setSharedData("tone_on", service.getSharedData("tone_on") == "true" and "false" or "true")
      showSettingsMenu()
    elseif which == 3 then
      service.setSharedData("emoji_on", service.getSharedData("emoji_on") == "true" and "false" or "true")
      showSettingsMenu()
    elseif which == 4 then
      service.startActivity(Intent(Intent.ACTION_VIEW, Uri.parse("https://wa.me/923261421100")).setFlags(Intent.FLAG_ACTIVITY_NEW_TASK))
    elseif which == 5 then
      dialog.dismiss()
    end
  end)
  
  local d = builder.create()
  d.getWindow().setType(2032)
  d.show()
end

-- 7. EXECUTION
pcall(function()
