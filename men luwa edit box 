-- 4. TONE PLAYER
local function playNotificationTone()
  if service.getSharedData("tone_on") == "true" then
    pcall(function()
      local uri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_NOTIFICATION)
      local r = RingtoneManager.getRingtone(service.getContext(), uri)
      if r then r.play() end
    end)
  end
end

-- 5. TRANSLATION (FIXED THREAD)
local function translateText(text, targetLang, callback)
  -- Create a Runnable with a proper 'run' method
  local runnable = Runnable {
    run = function()
      local translated = nil
      local errorMsg = nil
      pcall(function()
        local encoded = URLEncoder.encode(text, "UTF-8")
        local urlStr = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=" .. targetLang .. "&dt=t&q=" .. encoded
        local url = URL(urlStr)
        local conn = url.openConnection()
        conn.setConnectTimeout(5000)
        conn.setReadTimeout(5000)
        local reader = BufferedReader(InputStreamReader(conn.getInputStream()))
        local response = {}
        while true do
          local line = reader.readLine()
          if not line then break end
          table.insert(response, line)
        end
        reader.close()
        conn.disconnect()
        local jsonStr = table.concat(response, "")
        local json = JSONArray(jsonStr)
        local firstArray = json.getJSONArray(0)
        local translatedPart = firstArray.getJSONArray(0)
        translated = translatedPart.getString(0)
      end, function(e) errorMsg = tostring(e) end)
      
      -- Run callback on UI thread
      service.runOnUiThread(Runnable {
        run = function()
          if translated and translated ~= "" then
            callback(translated)
          else
            service.speak("Translation failed")
            callback(text)
          end
        end
      })
    end
  }
  Thread(runnable):start()
end

-- 6. VOICE RECOGNITION
function startVoiceTyping(targetBox)
  pcall(function()
    if service.getSharedData("vibrate_on") == "true" then
      local vib = service.getContext().getSystemService(Context.VIBRATOR_SERVICE)
      if vib then vib.vibrate(60) end
    end
    playNotificationTone()

    local speechRec = SpeechRecognizer.createSpeechRecognizer(service.getContext())
    local listener = RecognitionListener {
      onResults = function(results)
        local resultsArray = results.getParcelableArrayList(SpeechRecognizer.RESULTS_RECOGNITION)
        if resultsArray and resultsArray.size() > 0 then
          local spokenText = tostring(resultsArray.get(0))
          
          if translateEnabled then
            translateText(spokenText, translateTargetCode, function(translatedText)
              local finalText = applySmartEmoji(translatedText)
              service.insertText(targetBox, finalText .. " ")
              service.speak(translatedText)
            end)
          else
            local finalText = applySmartEmoji(spokenText)
            service.insertText(targetBox, finalText .. " ")
            service.speak(spokenText)
          end
        end
        speechRec.destroy()
        collectgarbage("collect")
      end,
      onError = function()
        service.asyncSpeak("Nahi samjha, dobara bole")
        speechRec.destroy()
      end,
    }
    
    local intent = Intent(RecognizerIntent.ACTION_RECOGNIZE_SPEECH)
    intent.putExtra(RecognizerIntent.EXTRA_LANGUAGE_MODEL, RecognizerIntent.LANGUAGE_MODEL_FREE_FORM)
    intent.putExtra(RecognizerIntent.EXTRA_LANGUAGE, selectedLangCode)
    intent.putExtra(RecognizerIntent.EXTRA_MAX_RESULTS, 1)
    
    speechRec.setRecognitionListener(listener)
    speechRec.startListening(intent)
  end)
end

