-- 2. UNIVERSAL FOCUS FINDER
local function getUniversalFocus()
  local root = service.getRootInActiveWindow()
  if not root then return service.getEditText() end
  local focusedNode = root.findFocus(AccessibilityNodeInfo.FOCUS_INPUT)
  if focusedNode and (focusedNode.isEditable() or focusedNode.getClassName() == "android.widget.EditText") then
    return focusedNode
  end
  return service.getEditText()
end

